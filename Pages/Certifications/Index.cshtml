@page
@model SeHrCertificationPortal.Pages.Certifications.IndexModel
@{
    ViewData["Title"] = "Employee Certifications Tracker";
}

<!-- Page Header with Report Action -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <!-- Page Title is handled in Layout -->
    </div>
    <div>
        @{
            bool hasActiveFilters = !string.IsNullOrEmpty(Model.SearchString) || Model.AgencyFilter.HasValue || Model.StatusFilter.HasValue;
        }
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-brand d-flex align-items-center fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#addDirectCertModal">
                <i data-lucide="plus" class="me-2" style="width: 18px;"></i> Add Certification
            </button>
            <form id="pdfExportForm" method="post" asp-page-handler="DownloadReport">
                <input type="hidden" name="searchString" value="@Model.SearchString" />
                <input type="hidden" name="agencyFilter" value="@Model.AgencyFilter" />
                <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                <input type="hidden" name="filterAnalytics" value="@Model.FilterAnalytics.ToString().ToLower()" />
                <input type="hidden" name="agencyChartBase64" id="agencyChartBase64" />
                <input type="hidden" name="certChartBase64" id="certChartBase64" />
                
                @if (hasActiveFilters)
                {
                    <button type="button" class="btn btn-brand d-flex align-items-center fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#downloadWarningModal">
                        <i data-lucide="file-down" class="me-2 text-white" style="width: 18px;"></i> Download Report
                    </button>
                }
                else
                {
                    <button type="button" onclick="generatePdfReport()" class="btn btn-brand d-flex align-items-center fw-bold shadow-sm">
                        <i data-lucide="file-down" class="me-2 text-white" style="width: 18px;"></i> Download Report
                    </button>
                }
            </form>
        </div>
    </div>
</div>

<!-- ANALYTICS DASHBOARD -->
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold text-dark d-flex align-items-center" data-bs-toggle="collapse" href="#analyticsCollapse" role="button" aria-expanded="true" aria-controls="analyticsCollapse" style="cursor: pointer; user-select: none;">
        <i data-lucide="chevron-down" class="me-2" style="width: 20px; transition: transform 0.3s;" id="analyticsChevron"></i> Compliance & Coverage Analytics
    </h5>
    <div class="form-check form-switch fs-5">
        <input class="form-check-input" type="checkbox" role="switch" id="analyticsVisualToggle" @(Model.FilterAnalytics ? "checked" : "")>
        <label class="form-check-label fs-6 text-muted mt-1" for="analyticsVisualToggle">Table Filters Affect Visuals</label>
    </div>
</div>
<div class="collapse show" id="analyticsCollapse">
<div class="row mb-4">
    <div class="col-md-4">
        <div class="card bg-success text-white shadow-sm h-100 position-relative overflow-hidden">
            <div class="card-body position-relative z-1">
                <h6 class="text-uppercase fw-bold mb-1">Total Active</h6>
                <h2 class="mb-0">@Model.AnalyticsTotalActive</h2>
                <i data-lucide="award" class="position-absolute opacity-25" style="width: 50px; height: 50px; right: 15px; top: 15px; z-index: 0;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-warning text-dark shadow-sm h-100 position-relative overflow-hidden">
            <div class="card-body position-relative z-1">
                <h6 class="text-uppercase fw-bold mb-1"><i data-lucide="alert-triangle" class="me-1" style="width: 18px;"></i> Expiring Soon</h6>
                <h2 class="mb-0">@Model.AnalyticsExpiringSoon</h2>
                <div class="mt-2" title="@string.Join("\n", Model.ExpiringSoonDetails.Take(15))">
                    <small class="text-white-50" style="cursor: help;"><i data-lucide="info" class="me-1" style="width: 12px;"></i>Hover for details</small>
                </div>
                <i data-lucide="clock" class="position-absolute opacity-25" style="width: 50px; height: 50px; right: 15px; top: 15px; z-index: 0;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-danger text-white shadow-sm h-100 position-relative overflow-hidden">
            <div class="card-body position-relative z-1">
                <h6 class="text-uppercase fw-bold mb-1">Critical Lapses</h6>
                <h2 class="mb-0">@Model.AnalyticsExpired</h2>
                <div class="mt-2" title="@string.Join("\n", Model.ExpiredDetails.Take(15))">
                    <small class="text-white-50" style="cursor: help;"><i data-lucide="info" class="me-1" style="width: 12px;"></i>Hover for details</small>
                </div>
                <i data-lucide="alert-triangle" class="position-absolute opacity-25" style="width: 50px; height: 50px; right: 15px; top: 15px; z-index: 0;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white"><h6 class="mb-0 fw-bold">Top Agency Distribution</h6></div>
            <div class="card-body">
                <div class="position-relative w-100 mb-3" style="height: 250px;">
                    <canvas id="agencyChart"></canvas>
                </div>
                <div class="mt-3 table-responsive">
                    <table class="table table-sm table-borderless table-striped text-muted mb-0">
                        <tbody>
                            @foreach(var kv in Model.TopAgenciesList)
                            {
                                <tr>
                                    <td>@kv.Key</td>
                                    <td class="text-end fw-bold">@kv.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white"><h6 class="mb-0 fw-bold">Top 5 Certifications Held</h6></div>
            <div class="card-body">
                <div class="position-relative w-100 mb-3" style="height: 250px;">
                    <canvas id="certChart"></canvas>
                </div>
                <div class="mt-3 table-responsive">
                    <table class="table table-sm table-borderless table-striped text-muted mb-0">
                        <tbody>
                            @foreach(var kv in Model.TopCertsList)
                            {
                                <tr>
                                    <td>@kv.Key</td>
                                    <td class="text-end fw-bold">@kv.Value</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
</div>
<!-- /ANALYTICS DASHBOARD -->

<div class="card shadow-sm">
    <div class="card-header border-0 bg-transparent py-3">
        <div class="d-flex justify-content-between align-items-center">
            <h5 class="card-title fs-5 fw-bold text-dark mb-0">Employee Certifications</h5>
            
            <div class="card-tools d-flex align-items-center gap-2">
                <form method="get" id="filterForm" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <input type="hidden" name="FilterAnalytics" id="hiddenFilterAnalytics" value="@Model.FilterAnalytics.ToString().ToLower()" />
                    
                    <div class="input-group input-group-sm mb-0 me-2" style="max-width: 250px;">
                        <input type="text" asp-for="SearchString" class="form-control" placeholder="Search employee...">
                        <button class="btn btn-brand" type="submit">
                            <i data-lucide="search" class="text-white" style="width: 14px;"></i>
                        </button>
                    </div>
                    
                    <select asp-for="AgencyFilter" class="form-select form-select-sm" style="width: 200px;" asp-items="Model.AgencyOptions">
                        <option value="">All Agencies</option>
                    </select>

                    <select asp-for="StatusFilter" class="form-select form-select-sm" style="width: 150px;" asp-items="Html.GetEnumSelectList<SeHrCertificationPortal.Models.TrackerStatus>()">
                        <option value="">All Statuses</option>
                    </select>
                    
                    <button type="submit" class="btn btn-brand btn-sm d-flex align-items-center">
                        <i data-lucide="filter" class="me-1" style="width: 14px;"></i> Filter
                    </button>

                    @if (!string.IsNullOrEmpty(Model.SearchString) || Model.AgencyFilter.HasValue || Model.StatusFilter.HasValue)
                    {
                        <a asp-page="./Index" class="btn btn-outline-brand btn-sm d-flex align-items-center" title="Clear Filters">
                            <i data-lucide="x" style="width: 14px;"></i>
                        </a>
                    }
                </form>
            </div>
        </div>
    </div>
    
    <div class="card-body p-0 table-responsive">
        <table id="certificationsTable" class="table table-striped table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th>Employee</th>
                    <th>Agency / Board</th>
                    <th>Certification</th>
                    <th>Date Passed</th>
                    <th>Expiration Date</th>
                    <th class="text-center" style="width: 120px;">Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.PassedCertifications.Any())
                {
                    <tr>
                        <td colspan="12" class="text-center py-5 text-muted">
                            <i data-lucide="search-x" class="mb-2" style="width: 32px; height: 32px; opacity: 0.5;"></i>
                            <h5 class="fw-bold text-secondary mb-1">No Records Found</h5>
                            <p class="mb-0 small">We couldn't find any data matching your current search or filter criteria.</p>
                        </td>
                    </tr>
                }
                @foreach (var item in Model.PassedCertifications)
                {
                    <tr class="clickable-row" style="cursor: pointer;" data-employee-id="@item.EmployeeId" title="Click to view certification history">
                        <td>@item.Employee?.DisplayName</td>
                        <td>@(item.Agency?.Abbreviation ?? item.CustomAgencyName ?? "Custom")</td>
                        <td>@(item.Certification?.Name ?? item.CustomCertificationName ?? "Custom")</td>
                        <td>
                            @{
                                // By domain definition, passing date is basically RequestDate when it was passed. You can modify if needed.
                                // It could also be inferred from ExpirationDate minus duration, but for now we'll display RequestDate.
                            }
                            @item.RequestDate.ToString("MMM dd, yyyy") 
                        </td>
                        <td>
                            @if (item.ExpirationDate.HasValue)
                            {
                                @item.ExpirationDate.Value.ToString("MMM dd, yyyy")
                            }
                            else
                            {
                                <span class="text-muted fst-italic">None</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.Status == SeHrCertificationPortal.Models.RequestStatus.Revoked)
                            {
                                <span class="badge text-bg-secondary d-inline-flex align-items-center"><i data-lucide="minus-circle" class="me-1" style="width: 12px; height: 12px;"></i>Revoked</span>
                            }
                            else
                            {
                                var status = Model.GetComputedStatus(item.ExpirationDate);
                                switch (status)
                                {
                                    case SeHrCertificationPortal.Models.TrackerStatus.Expired:
                                        <span class="badge text-bg-danger d-inline-flex align-items-center"><i data-lucide="alert-triangle" class="me-1" style="width: 12px; height: 12px;"></i>Expired</span>
                                        break;
                                    case SeHrCertificationPortal.Models.TrackerStatus.ExpiringSoon:
                                        <span class="badge text-bg-warning d-inline-flex align-items-center"><i data-lucide="clock" class="me-1" style="width: 12px; height: 12px;"></i>Expiring Soon</span>
                                        break;
                                    case SeHrCertificationPortal.Models.TrackerStatus.Active:
                                        <span class="badge text-bg-success d-inline-flex align-items-center"><i data-lucide="check-circle" class="me-1" style="width: 12px; height: 12px;"></i>Active/Passed</span>
                                        break;
                                    case SeHrCertificationPortal.Models.TrackerStatus.Permanent:
                                        <span class="badge text-bg-info text-white d-inline-flex align-items-center"><i data-lucide="infinity" class="me-1" style="width: 12px; height: 12px;"></i>Permanent</span>
                                        break;
                                }
                            }
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-3 align-items-center">
                                <form method="post" class="m-0 p-0">
                                    <button type="submit" asp-page-handler="DownloadEmployeeHistoryPdf" asp-route-employeeId="@item.EmployeeId" class="btn btn-link p-0 m-0 border-0 text-info action-btn text-decoration-none" title="Print History">
                                        <i data-lucide="printer" style="width: 18px; height: 18px;"></i>
                                    </button>
                                </form>
                                @if (item.Status == SeHrCertificationPortal.Models.RequestStatus.Revoked)
                                {
                                    <a href="javascript:void(0)" class="text-success action-btn restore-cert-btn" data-request-id="@item.Id" title="Restore Certification">
                                        <i data-lucide="rotate-ccw" style="width: 18px; height: 18px;"></i>
                                    </a>
                                    <a href="javascript:void(0)" class="text-danger action-btn archive-cert-btn" data-request-id="@item.Id" title="Archive Certification">
                                        <i data-lucide="archive" style="width: 18px; height: 18px;"></i>
                                    </a>
                                }
                                else
                                {
                                    <a href="javascript:void(0)" class="text-primary action-btn edit-cert-btn" 
                                       data-request-id="@item.Id" 
                                       data-date-passed="@item.RequestDate.ToString("yyyy-MM-dd")" 
                                       data-expiration="@(item.ExpirationDate.HasValue ? item.ExpirationDate.Value.ToString("yyyy-MM-dd") : "")" 
                                       title="Edit Certification">
                                        <i data-lucide="edit" style="width: 18px; height: 18px;"></i>
                                    </a>
                                    <a href="javascript:void(0)" class="text-warning action-btn remove-cert-btn" data-request-id="@item.Id" title="Revoke Certification">
                                        <i data-lucide="minus-circle" style="width: 18px; height: 18px;"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer bg-transparent border-top-0 py-3">
        <nav aria-label="Page navigation" class="d-flex justify-content-end align-items-center gap-3">
            <label class="mb-0 text-muted small">
                Show 
                <select class="form-select form-select-sm d-inline-block w-auto mx-1 shadow-sm" onchange="window.location.href='?p=1&pageSize=' + this.value + '&SearchString=@Model.SearchString&AgencyFilter=@Model.AgencyFilter&StatusFilter=@Model.StatusFilter'">
                    @foreach(var size in new[] { 10, 15, 20, 25, 50 })
                    {
                         if (size == Model.PageSize)
                        {
                            <option value="@size" selected>@size</option>
                        }
                        else
                        {
                            <option value="@size">@size</option>
                        }
                    }
                </select> entries
            </label>
            <partial name="_PaginationPartial" model='new SeHrCertificationPortal.Models.PaginationViewModel {
                CurrentPage = Model.CurrentPage,
                TotalPages = Model.TotalPages,
                RouteParams = new Dictionary<string, string> {
                    { "pageSize", Model.PageSize.ToString() },
                    { "SearchString", Model.SearchString ?? "" },
                    { "AgencyFilter", Model.AgencyFilter?.ToString() ?? "" },
                    { "StatusFilter", Model.StatusFilter?.ToString() ?? "" }
                }
            }' />
        </nav>
    </div>
</div>

<div class="modal fade" id="addDirectCertModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="AddDirectCert">
            <div class="modal-content">
                <div class="modal-header bg-light">
                    <h5 class="modal-title fw-bold">
                        <i data-lucide="award" class="me-2 text-brand" style="width: 20px;"></i> Direct Certification Entry
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info py-2 px-3 mb-4 shadow-sm border-0" style="font-size: 0.9rem;">
                        <i data-lucide="info" class="me-1" style="width: 16px;"></i> This form bypasses the standard request lifecycle and immediately flags the certification as <strong>Active</strong>.
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Employee</label>
                        <select name="NewEmployeeId" id="newEmployeeIdSelect" class="form-select mb-2" required>
                            <option value="">-- Select Employee --</option>
                            <option value="-1" class="fw-bold text-brand">+ Add New Employee</option>
                            @if(Model.EmployeeOptions != null)
                            {
                                foreach(var emp in Model.EmployeeOptions)
                                {
                                    <option value="@emp.Value">@emp.Text</option>
                                }
                            }
                        </select>
                        <input type="text" name="NewEmployeeName" id="newEmployeeNameInput" class="form-control d-none" placeholder="Enter new employee's full name..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Issuing Agency</label>
                        <select name="NewAgencyId" id="newAgencyId" class="form-select" asp-items="Model.AgencyOptions" required>
                            <option value="">-- Select Agency --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold small text-muted text-uppercase">Certification</label>
                        <select name="NewCertificationId" id="newCertificationId" class="form-select" required disabled>
                            <option value="">-- Select Agency First --</option>
                            @if(Model.AllCertifications != null)
                            {
                                foreach(var cert in Model.AllCertifications)
                                {
                                    <option value="@cert.Id" data-agency-id="@cert.AgencyId">@cert.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Date Passed</label>
                            <input type="date" class="form-control" name="NewDatePassed" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold small text-muted text-uppercase">Expiration Date</label>
                            <input type="date" class="form-control" name="NewExpirationDate" />
                            <div class="form-text" style="font-size: 0.75rem;">Leave blank if permanent.</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary text-white fw-bold">Save Record</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="employeeHistoryModal" tabindex="-1" aria-labelledby="employeeHistoryModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-light">
                <h5 class="modal-title" id="employeeHistoryModalLabel">
                    <i data-lucide="user" class="me-2"></i><span id="modalEmployeeName">Employee History</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle mb-0" id="modalHistoryTable">
                        <thead class="table-light">
                            <tr>
                                <th>Agency</th>
                                <th>Certification</th>
                                <th>Date Passed</th>
                                <th>Expiration</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="modalHistoryBody">
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editCertModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="EditCert">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Certification Record</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="TargetCertId" id="editCertId" />
                    <input type="hidden" name="p" value="@Model.CurrentPage" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <input type="hidden" name="searchString" value="@Model.SearchString" />
                    <input type="hidden" name="agencyFilter" value="@Model.AgencyFilter" />
                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                    <input type="hidden" name="filterAnalytics" value="@Model.FilterAnalytics.ToString().ToLower()" />
                    <div class="mb-3">
                        <label class="form-label">Date Passed</label>
                        <input type="date" class="form-control" name="EditDatePassed" id="editDatePassed" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Expiration Date</label>
                        <input type="date" class="form-control" name="EditExpiration" id="editExpiration" />
                        <div class="form-text">Leave blank for permanent certifications.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="revokeCertModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="RevokeCert">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title text-dark">Revoke Certification</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="TargetCertId" id="revokeCertId" />
                    <input type="hidden" name="p" value="@Model.CurrentPage" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <input type="hidden" name="searchString" value="@Model.SearchString" />
                    <input type="hidden" name="agencyFilter" value="@Model.AgencyFilter" />
                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                    <input type="hidden" name="filterAnalytics" value="@Model.FilterAnalytics.ToString().ToLower()" />
                    <p>Are you sure you want to revoke this certification? It will remain visible but be marked as inactive.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Yes, Revoke</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="restoreCertModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="RestoreCert">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Restore Certification</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="TargetCertId" id="restoreCertId" />
                    <input type="hidden" name="p" value="@Model.CurrentPage" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <input type="hidden" name="searchString" value="@Model.SearchString" />
                    <input type="hidden" name="agencyFilter" value="@Model.AgencyFilter" />
                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                    <input type="hidden" name="filterAnalytics" value="@Model.FilterAnalytics.ToString().ToLower()" />
                    <p>Are you sure you want to restore this certification to active status?</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Yes, Restore</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="archiveCertModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="ArchiveCert">
            <div class="modal-content">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Archive Certification</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" name="TargetCertId" id="archiveCertId" />
                    <input type="hidden" name="p" value="@Model.CurrentPage" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <input type="hidden" name="searchString" value="@Model.SearchString" />
                    <input type="hidden" name="agencyFilter" value="@Model.AgencyFilter" />
                    <input type="hidden" name="statusFilter" value="@Model.StatusFilter" />
                    <input type="hidden" name="filterAnalytics" value="@Model.FilterAnalytics.ToString().ToLower()" />
                    <p>Are you sure you want to archive this certification? It will be removed from the active roster but preserved in the database history.</p>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-default" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Yes, Archive</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="modal fade" id="downloadWarningModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning">
                <h5 class="modal-title fw-bold text-dark">
                    <i data-lucide="alert-triangle" class="me-2" style="width: 20px;"></i> Filtered Report Notice
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>You are downloading a customized report based on your active filters:</p>
                <ul class="fw-bold text-dark mb-3">
                    @if (!string.IsNullOrEmpty(Model.SearchString)) { <li>Employee Search: "@Model.SearchString"</li> }
                    @if (Model.AgencyFilter.HasValue) { <li>Agency: @(Model.AgencyOptions?.FirstOrDefault(a => a.Value == Model.AgencyFilter.ToString())?.Text ?? "Selected")</li> }
                    @if (Model.StatusFilter.HasValue) { <li>Status: @Model.StatusFilter.ToString()</li> }
                </ul>
                
                @if (!Model.FilterAnalytics)
                {
                    <div class="alert alert-danger shadow-sm border-0 py-2 px-3 mb-0">
                        <i data-lucide="info" class="me-1" style="width: 16px;"></i> <strong>Note on Visuals:</strong> Your <em>'Table Filters Affect Visuals'</em> toggle is turned <strong>OFF</strong>. The KPI metrics and charts in this PDF will reflect the <strong>entire company</strong> dataset, but the data table will only contain the filtered records.
                    </div>
                }
                else
                {
                    <p class="mb-0 text-muted">Both the analytical charts and the data table in the PDF will be restricted to this filtered dataset.</p>
                }
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="generatePdfReport()" class="btn btn-primary text-white fw-bold d-flex align-items-center" data-bs-dismiss="modal">
                    <i data-lucide="download" class="me-2" style="width: 18px;"></i> Proceed to Download
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        function generatePdfReport() {
            var agencyCanvas = document.getElementById('agencyChart');
            var certCanvas = document.getElementById('certChart');
            
            // Convert to Base64 (using light background to prevent transparency issues in PDF)
            if (agencyCanvas) {
                var destCtx = cloneCanvasWithBg(agencyCanvas);
                document.getElementById('agencyChartBase64').value = destCtx.canvas.toDataURL("image/png");
            }
            if (certCanvas) {
                var destCtx = cloneCanvasWithBg(certCanvas);
                document.getElementById('certChartBase64').value = destCtx.canvas.toDataURL("image/png");
            }
            
            document.getElementById('pdfExportForm').submit();
        }

        // Helper to force a white background behind Chart.js transparent canvas exports
        function cloneCanvasWithBg(oldCanvas) {
            var newCanvas = document.createElement('canvas');
            var context = newCanvas.getContext('2d');
            newCanvas.width = oldCanvas.width;
            newCanvas.height = oldCanvas.height;
            context.fillStyle = "#FFFFFF";
            context.fillRect(0,0, newCanvas.width, newCanvas.height);
            context.drawImage(oldCanvas, 0, 0);
            return context;
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Analytics Chevron Animation
            var analyticsCollapse = document.getElementById('analyticsCollapse');
            var analyticsChevron = document.getElementById('analyticsChevron');
            if (analyticsCollapse && analyticsChevron) {
                analyticsCollapse.addEventListener('hide.bs.collapse', function () { analyticsChevron.style.transform = 'rotate(-90deg)'; });
                analyticsCollapse.addEventListener('show.bs.collapse', function () { analyticsChevron.style.transform = 'rotate(0deg)'; });
            }

            // Dynamic New Employee Toggle in Direct Entry Modal
            var employeeSelect = document.getElementById('newEmployeeIdSelect');
            var employeeNameInput = document.getElementById('newEmployeeNameInput');
            
            if (employeeSelect && employeeNameInput) {
                employeeSelect.addEventListener('change', function() {
                    if (this.value === '-1') {
                        employeeNameInput.classList.remove('d-none');
                        employeeNameInput.required = true;
                        employeeNameInput.focus();
                    } else {
                        employeeNameInput.classList.add('d-none');
                        employeeNameInput.required = false;
                        employeeNameInput.value = ''; // Clear out the value if they change their mind
                    }
                });
            }

            // Cascading Dropdown for Direct Entry Modal
            var agencySelect = document.getElementById('newAgencyId');
            var certSelect = document.getElementById('newCertificationId');
            if (agencySelect && certSelect) {
                agencySelect.addEventListener('change', function() {
                    var selectedAgency = this.value;
                    certSelect.value = ''; // Reset
                    
                    if (!selectedAgency) {
                        certSelect.disabled = true;
                        certSelect.options[0].text = "-- Select Agency First --";
                    } else {
                        certSelect.disabled = false;
                        certSelect.options[0].text = "-- Select Certification --";
                    }

                    Array.from(certSelect.options).forEach(opt => {
                        if (opt.value === '') return; // Skip default option
                        if (opt.getAttribute('data-agency-id') === selectedAgency) {
                            opt.hidden = false;
                        } else {
                            opt.hidden = true;
                        }
                    });
                });
            }

            // 1. MASTER TABLE CONTROLLER (Handles Actions AND Row Clicks)
            var certTable = document.getElementById('certificationsTable');
            var tableBody = certTable ? certTable.querySelector('tbody') : null;
            if (tableBody) {
                tableBody.addEventListener('click', function(e) {
                    
                    // A. Check if an EDIT icon was clicked
                    var editBtn = e.target.closest('.edit-cert-btn');
                    if (editBtn) {
                        e.preventDefault();
                        e.stopPropagation();
                        console.log('--- EDIT TRIGGERED ---');
                        document.getElementById('editCertId').value = editBtn.getAttribute('data-request-id');
                        document.getElementById('editDatePassed').value = editBtn.getAttribute('data-date-passed');
                        document.getElementById('editExpiration').value = editBtn.getAttribute('data-expiration');
                        new bootstrap.Modal(document.getElementById('editCertModal')).show();
                        return; // Stop execution
                    }

                    // B. Check if action icons were clicked
                    var revokeBtn = e.target.closest('.remove-cert-btn');
                    if (revokeBtn) {
                        e.preventDefault();
                        e.stopPropagation();
                        console.log('--- REVOKE TRIGGERED ---');
                        document.getElementById('revokeCertId').value = revokeBtn.getAttribute('data-request-id');
                        new bootstrap.Modal(document.getElementById('revokeCertModal')).show();
                        return; // Stop execution
                    }

                    // C. Check if a RESTORE icon was clicked
                    var restoreBtn = e.target.closest('.restore-cert-btn');
                    if (restoreBtn) {
                        e.preventDefault(); e.stopPropagation();
                        document.getElementById('restoreCertId').value = restoreBtn.getAttribute('data-request-id');
                        new bootstrap.Modal(document.getElementById('restoreCertModal')).show();
                        return;
                    }

                    // D. Check if an ARCHIVE icon was clicked
                    var archiveBtn = e.target.closest('.archive-cert-btn');
                    if (archiveBtn) {
                        e.preventDefault(); e.stopPropagation();
                        document.getElementById('archiveCertId').value = archiveBtn.getAttribute('data-request-id');
                        new bootstrap.Modal(document.getElementById('archiveCertModal')).show();
                        return;
                    }

                    // C. If neither action was clicked, handle the ROW CLICK (Employee Modal)
                    var row = e.target.closest('.clickable-row');
                    if (row) {
                        console.log('--- ROW TRIGGERED ---');
                        var requestId = row.getAttribute('data-request-id');
                        
                        // Set Modal Title
                        var employeeName = row.querySelector('td:first-child')?.textContent.trim() || 'Employee';
                        document.getElementById('modalEmployeeName').textContent = employeeName + "'s Certifications";

                        // Fetch Data
                        fetch('?handler=EmployeeHistory&employeeId=' + row.getAttribute('data-employee-id'))
                            .then(response => response.json())
                            .then(data => {
                                var tbodyHtml = '';
                                if (data.length === 0) {
                                    tbodyHtml = '<tr><td colspan="5" class="text-center text-muted fst-italic py-4">No certification history found.</td></tr>';
                                } else {
                                    data.forEach(function(item) {
                                        var badgeClass = 'bg-secondary';
                                        if (item.status === 'Active') badgeClass = 'bg-success';
                                        else if (item.status === 'ExpiringSoon') badgeClass = 'bg-warning text-dark';
                                        else if (item.status === 'Expired') badgeClass = 'bg-danger';
                                        else if (item.status === 'Permanent') badgeClass = 'bg-info text-dark';

                                        tbodyHtml += `<tr>
                                            <td>${item.agency}</td>
                                            <td>${item.certification}</td>
                                            <td>${item.datePassed}</td>
                                            <td>${item.expirationDate}</td>
                                            <td><span class="badge ${badgeClass}">${item.status}</span></td>
                                        </tr>`;
                                    });
                                }
                                document.getElementById('modalHistoryBody').innerHTML = tbodyHtml;
                                if(window.lucide) { window.lucide.createIcons(); }
                                new bootstrap.Modal(document.getElementById('employeeHistoryModal')).show();
                            })
                            .catch(err => console.error('Fetch error:', err));
                    }
                });
            }

            // 2. ANALYTICS TOGGLE LOGIC
            var toggle = document.getElementById('analyticsVisualToggle');
            if (toggle) {
                toggle.addEventListener('change', function() {
                    document.getElementById('hiddenFilterAnalytics').value = this.checked;
                    document.getElementById('filterForm').submit();
                });
            }

            var analyticsCollapse = document.getElementById('analyticsCollapse');
            var analyticsChevron = document.getElementById('analyticsChevron');
            
            if (analyticsCollapse && analyticsChevron) {
                // Add smooth CSS transition
                analyticsChevron.style.transition = 'transform 0.3s ease';

                // Check stored state on load
                var isExpanded = sessionStorage.getItem('analyticsExpanded');
                if (isExpanded === 'false') {
                    analyticsCollapse.classList.remove('show');
                    analyticsChevron.style.transform = 'rotate(-90deg)';
                } else {
                    analyticsChevron.style.transform = 'rotate(0deg)';
                }

                // Fire instantly when the user clicks
                analyticsCollapse.addEventListener('hide.bs.collapse', function () { 
                    analyticsChevron.style.transform = 'rotate(-90deg)'; 
                    sessionStorage.setItem('analyticsExpanded', 'false');
                });
                analyticsCollapse.addEventListener('show.bs.collapse', function () { 
                    analyticsChevron.style.transform = 'rotate(0deg)'; 
                    sessionStorage.setItem('analyticsExpanded', 'true');
                });
            }

            // 3. RENDER CHART.JS (Keep your existing Html.Raw C# injections here)
            // Use IntersectionObserver to guarantee the Bootstrap collapse is fully open 
            // and the canvas has physical dimensions before we allow Chart.js to draw.
            var analyticsContainer = document.getElementById('analyticsCollapse');
            
            if (analyticsContainer) {
                var observer = new IntersectionObserver(function(entries) {
                    if(entries[0].isIntersecting) {
                        // Element is visible, safe to draw charts!
                        var agencyCtx = document.getElementById('agencyChart').getContext('2d');
                        new Chart(agencyCtx, {
                            type: 'doughnut',
                            data: {
                                labels: @Html.Raw(Model.AgencyChartLabels),
                                datasets: [{ data: @Html.Raw(Model.AgencyChartData), backgroundColor: ['#0d6efd', '#6c757d', '#198754', '#ffc107', '#dc3545'] }]
                            },
                            options: { 
                                animation: false,
                                responsive: true, 
                                maintainAspectRatio: false
                            }
                        });

                        var certCtx = document.getElementById('certChart').getContext('2d');
                        new Chart(certCtx, {
                            type: 'bar',
                            data: {
                                labels: @Html.Raw(Model.CertChartLabels),
                                datasets: [{ label: 'Active Employees', data: @Html.Raw(Model.CertChartData), backgroundColor: '#0d6efd' }]
                            },
                            options: { 
                                animation: false,
                                responsive: true, 
                                maintainAspectRatio: false, 
                                indexAxis: 'y',
                                plugins: {
                                    legend: { display: false }
                                },
                                scales: {
                                    x: {
                                        beginAtZero: true,
                                        ticks: { stepSize: 1 }
                                    },
                                    y: {
                                        ticks: {
                                            callback: function(value) {
                                                var lbl = this.getLabelForValue(value) || '';
                                                return lbl.length > 25 ? lbl.substring(0, 25) + '...' : lbl;
                                            }
                                        }
                                    }
                                }
                            }
                        });
                        
                        // Stop observing once drawn so it doesn't re-animate every scroll
                        observer.disconnect();
                    }
                }, { threshold: 0.1 });
                
                observer.observe(analyticsContainer);
            }

            if(window.lucide) { window.lucide.createIcons(); }
        });
    </script>
}
