@page
@model ErrorModel
@{
    ViewData["Title"] = "System Error";
}

<div class="row min-vh-100 align-items-center justify-content-center">
    <div class="col-md-6 text-center">
        <div class="card shadow-sm border-0">
            <div class="card-body p-5">
                <i data-lucide="alert-triangle" class="text-danger mb-4" style="width: 64px; height: 64px;"></i>
                <h2 class="fw-bold text-dark mb-3">System Error Encountered</h2>
                <p class="text-muted fs-5 mb-4">
                    A critical system error occurred while processing your request. 
                    IT Support has been notified securely inline with our Site Reliability protocols.
                </p>

                @if (Model.ShowRequestId)
                {
                    <div class="bg-light p-3 rounded mb-4 text-start">
                        <strong class="text-secondary">Request ID:</strong> 
                        <code class="text-dark">@Model.RequestId</code>
                    </div>
                }

                <a href="/" class="btn btn-primary btn-lg shadow-sm">
                    <i data-lucide="home" class="me-2"></i>Return to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
